# === TradingClaw Configuration ===

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# OpenRouter API Key(s) (comma-separated for rotation)
OPENROUTER_API_KEY=

# Comma-separated Telegram user IDs allowed to use the bot
ALLOWED_USER_IDS=

# Model to use (OpenRouter format)
MODEL=stepfun/step-3.5-flash:free

# Max agentic loop iterations per normal chat message
MAX_TOOL_ITERATIONS=10
# Enable for low-cost Railway profile (optimized for small instances)
RAILWAY_BUDGET_MODE=false
# Runtime role: all | main | light | ultra
TRADING_RUNTIME_ROLE=all
TELEGRAM_ENABLED=true
DAILY_LOG_DELIVERY_ENABLED=true
LOG_TO_FILE_ENABLED=true

# Autonomous trading token controls
TRADING_MAX_TOOL_ITERATIONS=24
REFLECTION_MAX_TOOL_ITERATIONS=8
TRADING_THINKING=medium
LIGHT_CYCLE_ENABLED=true
LIGHT_CYCLE_INTERVAL_MINUTES=5
ULTRA_LIGHT_CYCLE_ENABLED=true
ULTRA_LIGHT_CYCLE_INTERVAL_MINUTES=1
LIGHT_LLM_MODEL=
LIGHT_LLM_THINKING=off
LIGHT_LLM_MAX_TOOL_ITERATIONS=5
LIGHT_LLM_MAX_INPUT_TOKENS=10000
LIGHT_LLM_MAX_OUTPUT_TOKENS=800
AUTO_DEPLOY_BUYS_ENABLED=true
AUTO_DEPLOY_BUYS_PER_CYCLE=2
AUTO_DEPLOY_CASH_THRESHOLD=0.40
AUTO_DEPLOY_TOPUP_CASH_THRESHOLD=0.55
AUTO_DEPLOY_MIN_SCORE=4
AUTO_DEPLOY_MAX_PENDING_BUY_ORDERS=3
AUTO_DEPLOY_LIMIT_BUFFER_BPS=25
DAILY_LOSS_LIMIT_AMOUNT=200
DAILY_LOSS_LIMIT_MIN_PERCENT=0.0075
ALPACA_REQUEST_TIMEOUT_MS=12000
SCREENER_MAX_RUNTIME_MS=90000
SCREENER_BATCH_SIZE=80
MAX_BAR_STALENESS_HOURS=120
TRADING_FEE_30D_VOLUME_USD=0

# Self-improvement pipeline (runs after reflection cycle)
SELF_IMPROVE_ENABLED=false
SELF_IMPROVE_MODE=internal
SELF_IMPROVE_MODEL=
SELF_IMPROVE_THINKING=medium
SELF_IMPROVE_MAX_TOOL_ITERATIONS=16
SELF_IMPROVE_COMMAND_TIMEOUT_MS=900000
# Used when SELF_IMPROVE_MODE=gemini-cli. Supports {PROMPT_FILE} placeholder.
SELF_IMPROVE_GEMINI_COMMAND=
SELF_IMPROVE_BUILD_COMMAND=npm run build
SELF_IMPROVE_TEST_COMMAND=
SELF_IMPROVE_AUTO_RESTART=false
SELF_IMPROVE_RESTART_COMMAND=npm start
SELF_IMPROVE_RESTART_DELAY_MS=12000

# OpenAI API Key (for Whisper voice transcription)
OPENAI_API_KEY=

# ElevenLabs API Key (for Text-to-Speech)
ELEVENLABS_API_KEY=

# ElevenLabs Voice ID (optional)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Path to MCP Servers JSON config
MCP_SERVERS_CONFIG=./mcp_servers.json

# Heartbeat proactive scheduler
HEARTBEAT_ENABLED=true
HEARTBEAT_TIMEZONE=Europe/Berlin
HEARTBEAT_INTERVAL_MINUTES=60

# Optional web search key
TAVILY_API_KEY=

# Local webhook server
WEBHOOK_PORT=3000
WEBHOOK_JSON_LIMIT_KB=32
WEBHOOK_FORM_LIMIT_KB=8
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
WEBHOOK_RATE_LIMIT_MAX=20
WEBHOOK_SHARED_SECRET=
WEBHOOK_REQUIRE_SHARED_SECRET=false
ESCALATION_MAIN_URL=
ESCALATION_LIGHT_URL=
ESCALATION_SHARED_SECRET=
ESCALATION_REQUEST_TIMEOUT_MS=8000
TELEGRAM_NOTIFY_CYCLE_RESULTS=true
TELEGRAM_NOTIFY_CYCLE_STARTS=true
TELEGRAM_NOTIFY_TRADE_EVENTS=true
TELEGRAM_NOTIFY_FAST_CYCLE_SKIPS=true
TELEGRAM_NOTIFY_TOKEN_USAGE=true

# Optional Google Drive log shipping
GOOGLE_DRIVE_LOG_UPLOAD_ENABLED=false
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
DELETE_LOCAL_LOG_AFTER_UPLOAD=true

# === Alpaca Paper Trading ===
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
TRADING_CYCLE_HOURS=1
REFLECTION_CYCLE_HOURS=24
